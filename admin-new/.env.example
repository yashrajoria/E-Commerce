# Server-only backend URL (preferred for API routes / SSR). Never expose secrets here.
API_BASE_URL=http://localhost:8080

# Browser-visible fallbacks (optional; prefer API_BASE_URL on the server)
NEXT_PUBLIC_NEW_API_URL=http://localhost:8080/
NEXT_PUBLIC_BFF_URL=http://localhost:8088/

# Admin accounts are seeded by the backend (ADMIN_EMAIL / ADMIN_PASSWORD).
# Self-registration on this app is disabled.
